# ── Required ─────────────────────────────────────────────────────────────────
# Must be set explicitly. App refuses to start without it.
TARGET_ENVIRONMENT=mock          # mock | staging | production
MESSAGING_PROVIDER=mock          # mock | ringcentral
DATABASE_URL=postgresql+asyncpg://adit:adit@localhost:5432/adit_sim

# ── Anthropic (optional in mock mode, required for LLM persona + judge) ──────
ANTHROPIC_API_KEY=

# ── RingCentral (required only if MESSAGING_PROVIDER=ringcentral) ─────────────
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT=
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_FROM_NUMBER=
TARGET_AGENT_NUMBER=             # the AI Front Desk's SMS number
PUBLIC_WEBHOOK_URL=              # publicly reachable URL for inbound webhook
